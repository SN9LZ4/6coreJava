<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.image.*?>
<?import java.lang.String?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cinema.controller.PanierController"
            prefHeight="700.0" prefWidth="1000.0"
            styleClass="main-container">
    
    <stylesheets>
        <URL value="@styles/front.css" />
        <URL value="@styles/style.css" />
    </stylesheets>
    
    <!-- Top Navigation Bar -->
    <top>
        <VBox spacing="0">
            <!-- Top Info Bar -->
            <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-info-bar">
                <padding>
                    <Insets bottom="10" left="20" right="20" top="10" />
                </padding>

                <Label styleClass="info-text" text="123 Esprit, Elghazela, Tunisie">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <Image url="@icons/location-pin.png" />
                        </ImageView>
                    </graphic>
                    <effect>
                        <Glow level="0.2" />
                    </effect>
                </Label>

                <Label styleClass="info-text" text="+216 24 705 213">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <Image url="@icons/phone-call.png" />
                        </ImageView>
                    </graphic>
                </Label>

                <Label styleClass="info-text" text="ChouFliFilm@gmail.com">
                    <graphic>
                        <ImageView fitHeight="16" fitWidth="16">
                            <Image url="@icons/email-envelope.png" />
                        </ImageView>
                    </graphic>
                </Label>
            </HBox>

            <!-- Main Navigation -->
            <HBox alignment="CENTER" spacing="20" styleClass="main-nav">
                <padding>
                    <Insets bottom="12" left="20" right="20" top="12" />
                </padding>
                
                <!-- Logo -->
                <ImageView fitHeight="40" fitWidth="40">
                    <Image url="@icons/logo.png" />
                </ImageView>
                
                <Region HBox.hgrow="ALWAYS" />
                
                <!-- Navigation Buttons -->
                <Button onAction="#handleHomeClick" styleClass="nav-btn" text="Home" />
                <Button onAction="#handleReservationClick" styleClass="nav-btn" text="Make Reservation" />
            </HBox>
        </VBox>
    </top>
    
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox spacing="30" alignment="CENTER">
                <padding>
                    <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
                </padding>
                <VBox spacing="25" style="-fx-background-color: rgba(25, 25, 35, 0.8); -fx-padding: 30.0; -fx-background-radius: 15;">
                    <effect>
                        <DropShadow height="20.0" radius="9.5" spread="0.2" width="20.0">
                            <color>
                                <Color opacity="0.7" />
                            </color>
                        </DropShadow>
                    </effect>
                    <Label text="Your Cart" styleClass="main-title" />
                    <TableView fx:id="cartTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="filmColumn" text="Film" prefWidth="200" styleClass="table-column"/>
                            <TableColumn fx:id="salleColumn" text="Theater" prefWidth="150" styleClass="table-column"/>
                            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150" styleClass="table-column"/>
                            <TableColumn fx:id="placesColumn" text="Seats" prefWidth="100" styleClass="table-column"/>
                            <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" styleClass="table-column"/>
                            <TableColumn fx:id="prixColumn" text="Price" prefWidth="100" styleClass="table-column"/>
                            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200" styleClass="table-column"/>
                        </columns>
                    </TableView>
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Label text="Total:" styleClass="total-label"/>
                        <Label fx:id="totalPriceLabel" styleClass="total-price"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: #1a1a2e; -fx-padding: 15;">
            <Text text=" 2025 CinémaRéservation - The Ultimate Cinema Experience" style="-fx-fill: #6c757d; -fx-font-size: 12;"/>
        </HBox>
    </bottom>
</BorderPane>
