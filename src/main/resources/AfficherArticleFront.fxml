<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AfficherArticleFront"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #ffffff;">

    <!-- NAV BAR BLEUE -->
    <HBox alignment="CENTER_LEFT" spacing="15"
          prefHeight="60" AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
          style="-fx-background-color: #ff0000; -fx-padding: 0 20 0 20;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 8, 0, 0, 2);">

        <!-- Logo bien intégré -->
        <ImageView fx:id="logoImage" fitHeight="35" fitWidth="35" preserveRatio="true"/>

        <!-- Titre -->
        <Label text="Tous les Articles"
               style="-fx-text-fill: white; -fx-font-size: 22px;
                      -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>
    </HBox>

    <!-- Scrollable Article Cards -->
    <ScrollPane fitToWidth="true" fitToHeight="true"
                AnchorPane.topAnchor="60.0" AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                style="-fx-background-color: transparent;">

        <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 20;">
            <FlowPane fx:id="flowPane"
                      hgap="20.0" vgap="20.0"
                      alignment="CENTER"
                      prefWrapLength="900.0"
                      style="-fx-background-color: #ffffff;">
                <padding>
                    <Insets top="0.0" right="10.0" bottom="0.0" left="10.0"/>
                </padding>
            </FlowPane>
        </VBox>

    </ScrollPane>
</AnchorPane>
