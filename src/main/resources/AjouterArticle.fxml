<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AjouterArticle"
            prefHeight="700.0" prefWidth="900.0"
            style="-fx-background-color: #1e1e1e;"> <!-- Dark Background -->

   <!-- Background Effects -->
   <Circle radius="180" style="-fx-fill: radial-gradient(radius 100%, rgba(255,0,0,0.08), transparent);"
           AnchorPane.leftAnchor="-100" AnchorPane.topAnchor="-100"/>
   <Rectangle width="280" height="700" style="-fx-fill: linear-gradient(to bottom, rgba(128,128,128,0.08), transparent);"
              AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0"/>

   <VBox alignment="TOP_CENTER" spacing="30"
         AnchorPane.leftAnchor="50.0" AnchorPane.rightAnchor="50.0"
         AnchorPane.topAnchor="40.0" AnchorPane.bottomAnchor="40.0">

      <!-- Title -->
      <HBox alignment="CENTER" spacing="15">
         <Rectangle width="50" height="3" arcWidth="4" arcHeight="4"
                    style="-fx-fill: #e53935;"/> <!-- Red -->
         <Label text="📝 Ajouter un Article"
                style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI';"/>
         <Rectangle width="50" height="3" arcWidth="4" arcHeight="4"
                    style="-fx-fill: #e53935;"/>
      </HBox>

      <!-- Form Section -->
      <GridPane hgap="25" vgap="25"
                style="-fx-background-color: #2e2e2e; -fx-background-radius: 18; -fx-padding: 35;
                         -fx-border-color: #444; -fx-border-width: 1; -fx-border-radius: 18;
                         -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, 0, 5);"
                maxWidth="800">
         <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="150"/>
            <ColumnConstraints halignment="LEFT" minWidth="250"/>
            <ColumnConstraints halignment="CENTER" minWidth="150"/>
         </columnConstraints>

         <!-- Nom -->
         <Label text="Nom d’article:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1"
                    promptText="Entrez le nom"
                    style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-background-radius: 8;
                              -fx-padding: 8; -fx-font-size: 14px;"/>

         <!-- Catégorie -->
         <Label text="Catégorie:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <ComboBox fx:id="categorieField" GridPane.rowIndex="1" GridPane.columnIndex="1"
                   promptText="Choisir une catégorie"
                   style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-font-size: 14px;
                             -fx-background-radius: 8;"/>

         <!-- Date -->
         <Label text="Date:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <DatePicker fx:id="dateField" GridPane.rowIndex="2" GridPane.columnIndex="1"
                     style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                               -fx-background-radius: 8;"/>

         <!-- Image Field -->
         <Label text="Image:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="1">
            <TextField fx:id="imageArticleField" editable="false"
                       promptText="Aucun fichier sélectionné"
                       style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                                  -fx-background-radius: 8 0 0 8; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
            <Button text="Parcourir..." onAction="#handleImageUpload"
                    style="-fx-background-color: #e53935; -fx-text-fill: white;
                               -fx-background-radius: 0 8 8 0; -fx-font-size: 14px;"/>
         </HBox>

         <!-- Image Preview -->
         <Label text="Aperçu image:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <StackPane GridPane.rowIndex="4" GridPane.columnIndex="1">
            <ImageView fx:id="articleImageView" fitHeight="180" fitWidth="180" preserveRatio="true"
                       style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.3, 0, 0);"/>
         </StackPane>

         <!-- Contenu as TextField -->
         <Label text="Contenu:" GridPane.rowIndex="5" GridPane.columnIndex="0"
                style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         <TextField fx:id="contenuField" GridPane.rowIndex="5" GridPane.columnIndex="1"
                    promptText="Entrez le contenu"
                    style="-fx-background-color: #3a3a3a; -fx-text-fill: white;
                              -fx-background-radius: 8; -fx-font-size: 14px;" HBox.hgrow="ALWAYS"/>
      </GridPane>

      <!-- Button -->
      <Button fx:id="btnAjouter" text="Créer l’article" onAction="#addArticle"
              style="-fx-background-color: #e53935; -fx-text-fill: white;
                       -fx-font-size: 16px; -fx-font-weight: bold;
                       -fx-background-radius: 10; -fx-padding: 12 30;
                       -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 2);"/>
   </VBox>
</AnchorPane>
