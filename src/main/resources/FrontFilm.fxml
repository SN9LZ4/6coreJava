<!-- ... (imports identiques à ta version précédente) -->

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.ComboBox?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.FrontController"
            prefWidth="1200.0" prefHeight="800.0"
            style="-fx-background-color: linear-gradient(to bottom right, #ffffff, #f4f6f8);">

    <!-- Barre de navigation -->
    <HBox style="-fx-background-color: #ff0101; -fx-padding: 15 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);"
          alignment="CENTER_LEFT"
          prefHeight="70"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <ImageView fitHeight="40" fitWidth="40" preserveRatio="true" />

        <Label text="ChoufliFilm"
               style="-fx-font-size: 28px; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 0 30 0 15; -fx-font-family: 'Segoe UI Semibold';"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="Accueil" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;"/>
        <Button text="Films" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15px; -fx-background-radius: 5px; -fx-padding: 8 20; -fx-cursor: hand;"/>
        <Button text="Favoris" style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-weight: bold; -fx-font-size: 15px; -fx-cursor: hand;"/>
    </HBox>

    <!-- Panneau de recherche -->
    <VBox spacing="15"
          style="-fx-background-color: white; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2); -fx-padding: 25;"
          AnchorPane.topAnchor="85.0" AnchorPane.leftAnchor="30.0" AnchorPane.rightAnchor="30.0">

        <Label text="🎯 Recherche avancée"
               style="-fx-font-size: 20px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>

        <HBox spacing="20" alignment="CENTER_LEFT">
            <TextField fx:id="titreField" promptText="🎬 Titre du film" prefWidth="220"
                       style="-fx-background-color: #f1f1f1; -fx-background-radius: 8px; -fx-border-color: #ddd; -fx-padding: 10 15;"/>

            <TextField fx:id="directeurField" promptText="🎥 Réalisateur" prefWidth="220"
                       style="-fx-background-color: #f1f1f1; -fx-background-radius: 8px; -fx-border-color: #ddd; -fx-padding: 10 15;"/>

            <ComboBox fx:id="genreComboBox" promptText="🎭 Genre" prefWidth="200"
                      style="-fx-background-color: #f1f1f1; -fx-background-radius: 8px; -fx-border-color: #ddd;"/>

            <TextField fx:id="noteField" promptText="⭐ Note min." prefWidth="120"
                       style="-fx-background-color: #f1f1f1; -fx-background-radius: 8px; -fx-border-color: #ddd; -fx-padding: 10 15;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="🔍 Rechercher" onAction="#onRechercherClick"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-padding: 10 20;"/>

            <Button text="⟲ Réinitialiser" onAction="#onResetClick"
                    style="-fx-background-color: white; -fx-text-fill: #e74c3c; -fx-border-color: #e74c3c; -fx-border-radius: 8px; -fx-padding: 10 20;"/>
        </HBox>
    </VBox>

    <!-- Résultats -->
    <VBox spacing="20"
          AnchorPane.topAnchor="230.0"
          AnchorPane.leftAnchor="30.0"
          AnchorPane.rightAnchor="30.0"
          AnchorPane.bottomAnchor="20.0">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="🎬 Résultats"
                   style="-fx-font-size: 18px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>

            <Label fx:id="resultCount" text="0 films trouvés"
                   style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <ComboBox fx:id="sortComboBox" promptText="Trier par"
                      style="-fx-background-color: #f1f1f1; -fx-background-radius: 8px; -fx-border-color: #ddd;">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Note (décroissant)" />
                        <String fx:value="Date de sortie" />
                        <String fx:value="Titre (A-Z)" />
                    </FXCollections>
                </items>
            </ComboBox>
        </HBox>

        <!-- Zone de films (grille) -->
        <ScrollPane fx:id="filmContainerScroll"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <TilePane fx:id="filmContainer"
                      prefColumns="3"
                      hgap="20"
                      vgap="20"
                      style="-fx-padding: 15;">
                <!-- Les cartes de films seront ajoutées dynamiquement ici -->
            </TilePane>
        </ScrollPane>
    </VBox>
</AnchorPane>
