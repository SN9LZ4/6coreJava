<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.AfficherArticle"
            prefHeight="700.0" prefWidth="1000.0"
            style="-fx-background-color: #1e1e1e;">

    <!-- Top Title -->
    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color: #2e2e2e; -fx-background-radius: 10;
                 -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 3);"
          AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">

        <!-- Icon + Title -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Rectangle width="5" height="40" arcWidth="5" arcHeight="5" style="-fx-fill: #e53935;" />
            <Label text="📋 Liste des Articles"
                   style="-fx-font-size: 24px; -fx-text-fill: white; -fx-font-weight: bold;
                          -fx-font-family: 'Segoe UI';"/>
        </HBox>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Ajouter Article Button -->
        <Button fx:id="btnAjouterArticle" text="➕ Ajouter Article"
                onAction="#ouvrirAjouterArticle"
                style="-fx-background-color: #2196f3; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 10 18;"/>
    </HBox>

    <!-- Table of Articles -->
    <TableView fx:id="articleTable"
               AnchorPane.topAnchor="90.0" AnchorPane.leftAnchor="20.0"
               AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0"
               prefHeight="580.0" prefWidth="960.0"
               style="-fx-background-color: #2e2e2e; -fx-border-color: #444;
                      -fx-border-width: 1; -fx-border-radius: 10;">

        <columns>
            <TableColumn fx:id="nomColumn" text="Nom d’article" prefWidth="120"/>
            <TableColumn fx:id="categorieColumn" text="Catégorie" prefWidth="120"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="100"/>
            <TableColumn fx:id="contenuColumn" text="Contenu" prefWidth="200"/>
            <TableColumn fx:id="imageColumn" text="Image" prefWidth="150"/>
            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="200"/>
            <TableColumn fx:id="commentaireColumn" text="Commentaires" prefWidth="150"/>
        </columns>
    </TableView>

</AnchorPane>
