<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.ListeCommentaires"
            prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: white;">

    <VBox spacing="20.0" alignment="TOP_CENTER" AnchorPane.topAnchor="20.0"
          AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0">

        <Label text=" Liste des Commentaires"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0d1b2a;"/>

        <TableView fx:id="commentaireTable" prefWidth="750.0" prefHeight="500.0">
            <columns>
                <TableColumn fx:id="nomColumn" text="Nom utilisateur" prefWidth="200"/>
                <TableColumn fx:id="contenuColumn" text="Contenu" prefWidth="400"/>
                <TableColumn fx:id="actionColumn" text="Action" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>
</AnchorPane>
