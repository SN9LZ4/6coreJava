<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.SalleFrontController"
            prefWidth="1200.0" prefHeight="800.0"
            style="-fx-background-color: #f5f7fa;">

    <!-- Barre de navigation -->
    <HBox style="-fx-background-color: linear-gradient(to right, #ff0101, #ff0101);
                 -fx-padding: 15 25;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 5);"
          alignment="CENTER_LEFT"
          prefHeight="70"
          AnchorPane.topAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">

        <Label text="GESTION DES SALLES"
               style="-fx-font-size: 24px;
                      -fx-text-fill: white;
                      -fx-font-weight: bold;
                      -fx-font-family: 'Segoe UI';"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Affichage du nom du film sélectionné -->
    <Label fx:id="filmTitleLabel"
           text="Film sélectionné : Inconnu"
           AnchorPane.topAnchor="75.0" AnchorPane.leftAnchor="30.0"
           style="-fx-font-size: 20px; -fx-text-fill: #ff0101; -fx-font-weight: bold; -fx-font-family: 'Segoe UI';"/>

    <!-- Panneau de recherche -->
    <VBox style="-fx-background-color: white;
                -fx-background-radius: 8px;
                -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 2);
                -fx-padding: 20;"
          AnchorPane.topAnchor="110.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0">

        <Label text="Recherche avancée"
               style="-fx-font-size: 18px;
                     -fx-text-fill: #2C3E50;
                     -fx-font-weight: bold;
                     -fx-padding: 0 0 15 0;
                     -fx-font-family: 'Segoe UI';"/>

        <GridPane hgap="15" vgap="15">
            <columnConstraints>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
                <ColumnConstraints percentWidth="25"/>
            </columnConstraints>

            <rowConstraints>
                <RowConstraints prefHeight="40"/>
                <RowConstraints prefHeight="40"/>
                <RowConstraints prefHeight="40"/>
            </rowConstraints>

            <Label text="Type de salle:" GridPane.columnIndex="0" GridPane.rowIndex="0"
                   style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="typeSalleComboBox" GridPane.columnIndex="1" GridPane.rowIndex="0"
                      style="-fx-background-radius: 4px; -fx-font-size: 14px;"/>

            <Label text="État:" GridPane.columnIndex="2" GridPane.rowIndex="0"
                   style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="etatSalleComboBox" GridPane.columnIndex="3" GridPane.rowIndex="0"
                      style="-fx-background-radius: 4px; -fx-font-size: 14px;"/>

            <Label text="Capacité min:" GridPane.columnIndex="0" GridPane.rowIndex="1"
                   style="-fx-font-weight: bold;"/>
            <TextField fx:id="capaciteMinField" promptText="Min" GridPane.columnIndex="1" GridPane.rowIndex="1"
                       style="-fx-background-radius: 4px;"/>

            <Label text="Capacité max:" GridPane.columnIndex="2" GridPane.rowIndex="1"
                   style="-fx-font-weight: bold;"/>
            <TextField fx:id="capaciteMaxField" promptText="Max" GridPane.columnIndex="3" GridPane.rowIndex="1"
                       style="-fx-background-radius: 4px;"/>

            <HBox spacing="15" alignment="CENTER_RIGHT" GridPane.columnIndex="3" GridPane.rowIndex="2">
                <Button text="Rechercher" fx:id="rechercherButton" onAction="#onRechercherClick"
                        style="-fx-background-color: #ff0101; -fx-text-fill: white;
                               -fx-background-radius: 5px; -fx-padding: 8 20;"/>

                <Button text="Réinitialiser" fx:id="reinitialiserButton" onAction="#onResetClick"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-background-radius: 5px; -fx-padding: 8 20;"/>
            </HBox>
        </GridPane>
    </VBox>

    <!-- Résultats -->
    <VBox spacing="20"
          AnchorPane.topAnchor="330.0"
          AnchorPane.leftAnchor="20.0"
          AnchorPane.rightAnchor="20.0"
          AnchorPane.bottomAnchor="20.0">

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Résultats"
                   style="-fx-font-size: 16px;
                          -fx-text-fill: #ff0101;
                          -fx-font-weight: bold;
                          -fx-font-family: 'Segoe UI';"/>

            <Label fx:id="resultCountLabel" text="0 salles trouvées"
                   style="-fx-font-size: 14px; -fx-text-fill: #ff0101;"/>

            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;">
            <TilePane fx:id="salleContainer"
                      hgap="20" vgap="20"
                      prefColumns="3"
                      style="-fx-padding: 10;"/>
        </ScrollPane>
    </VBox>

</AnchorPane>
