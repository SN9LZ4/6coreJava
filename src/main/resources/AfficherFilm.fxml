<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controllers.AfficherFilmController"
            prefHeight="800.0" prefWidth="1200.0"
            style="-fx-background-color: #;">

    <!-- Header Section - Dark Professional Header -->
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #212529; -fx-padding: 15;" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Label text="ADMINISTRATION - GESTION DES FILMS" style="-fx-text-fill: #e9ecef; -fx-font-weight: bold; -fx-font-size: 18;">
            <font>
                <Font name="Segoe UI" size="18.0" />
            </font>
        </Label>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="ajouterButton" text="+ Ajouter Film"
                onAction="#handleAjouterFilm"
                style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 4;">
            <effect>
                <DropShadow color="rgba(13,110,253,0.4)" radius="5" spread="0.2"/>
            </effect>
        </Button>
    </HBox>

    <!-- Main Content -->
    <SplitPane dividerPositions="0.25" AnchorPane.topAnchor="60" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">
        <items>
            <!-- Left Side - Film List -->
            <VBox spacing="15" style="-fx-padding: 15; -fx-background-color: white; -fx-background-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-border-color: #dee2e6; -fx-border-width: 1; -fx-border-radius: 6;">
                <Label text="LISTE DES FILMS" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #495057;">
                    <font>
                        <Font name="Segoe UI Semibold" size="14.0" />
                    </font>
                </Label>
                <TextField fx:id="searchField" promptText="Rechercher un film..."
                           style="-fx-background-radius: 4; -fx-border-color: #ced4da; -fx-border-radius: 4; -fx-padding: 5;"/>
                <ListView fx:id="rlist" prefWidth="250"
                          style="-fx-border-radius: 4; -fx-background-radius: 4; -fx-border-color: #dee2e6; -fx-border-width: 1;"
                          fixedCellSize="40"/>
            </VBox>

            <!-- Right Side - Film Details -->
            <VBox spacing="20" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 6; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 8, 0, 0, 2); -fx-border-color: #dee2e6; -fx-border-width: 1; -fx-border-radius: 6;">
                <HBox spacing="30" alignment="TOP_LEFT">
                    <!-- Film Poster -->
                    <VBox spacing="15" alignment="CENTER">
                        <ImageView fx:id="filmImageView" fitWidth="220" fitHeight="330" preserveRatio="true"
                                   style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2); -fx-border-color: #e9ecef; -fx-border-width: 1;"/>
                        <HBox spacing="15" alignment="CENTER">
                            <Button fx:id="modifyButton" text="Modifier"
                                    onAction="#handleModify"
                                    style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 4;">
                                <effect>
                                    <DropShadow color="rgba(108,117,125,0.4)" radius="5" spread="0.2"/>
                                </effect>
                            </Button>
                            <Button fx:id="deleteButton" text="Supprimer"
                                    onAction="#handleDelete"
                                    style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 4;">
                                <effect>
                                    <DropShadow color="rgba(220,53,69,0.4)" radius="5" spread="0.2"/>
                                </effect>
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Film Details -->
                    <GridPane hgap="15" vgap="15" style="-fx-padding: 10;">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                            <ColumnConstraints minWidth="300"/>
                        </columnConstraints>

                        <Label text="Titre:" style="-fx-font-weight: bold; -fx-text-fill: #212529;"/>
                        <Label fx:id="titreLabel" GridPane.columnIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Directeur:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="1"/>
                        <Label fx:id="directeurLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Note:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="2"/>
                        <Label fx:id="noteLabel" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Genre:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="3"/>
                        <Label fx:id="genreLabel" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Durée:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="4"/>
                        <Label fx:id="dureeLabel" GridPane.columnIndex="1" GridPane.rowIndex="4" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Date Début:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="5"/>
                        <Label fx:id="dateDebutLabel" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>

                        <Label text="Date Fin:" style="-fx-font-weight: bold; -fx-text-fill: #212529;" GridPane.rowIndex="6"/>
                        <Label fx:id="dateFinLabel" GridPane.columnIndex="1" GridPane.rowIndex="6" style="-fx-font-size: 14px; -fx-text-fill: #495057;"/>
                    </GridPane>
                </HBox>

                <!-- Description Section -->
                <VBox spacing="10" style="-fx-padding: 10;">
                    <Label text="DESCRIPTION" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #212529;">
                        <font>
                            <Font name="Segoe UI Semibold" size="14.0" />
                        </font>
                    </Label>
                    <WebView fx:id="descriptionWebView" prefHeight="200"
                             style="-fx-border-radius: 4; -fx-border-color: #dee2e6; -fx-border-width: 1;"/>
                </VBox>
            </VBox>
        </items>
    </SplitPane>

    <!-- Bottom Navigation -->
    <HBox spacing="15" alignment="BOTTOM_RIGHT" AnchorPane.bottomAnchor="20" AnchorPane.rightAnchor="20">
        <Button fx:id="retourButton" text="Retour au Tableau de Bord"
                onAction="#handleRetour"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25; -fx-background-radius: 4;">
            <effect>
                <DropShadow color="rgba(108,117,125,0.4)" radius="5" spread="0.2"/>
            </effect>
        </Button>
    </HBox>
</AnchorPane>